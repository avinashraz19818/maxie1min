#!/bin/bash
set -e
cd "$(dirname "$0")"
BOT_FILE="persnl_bot.py"
LOG_FILE="bot.log"
PID_FILE="bot.pid"
SESSION_FILE="user_session.session"
if [ -f "$PID_FILE" ]; then kill $(cat "$PID_FILE") 2>/dev/null || true; rm -f "$PID_FILE"; fi
pkill -f ".*${BOT_FILE}" 2>/dev/null || true
if [ ! -f "$SESSION_FILE" ]; then
  . .venv/bin/activate
  python3 "$BOT_FILE"
  exit 0
fi
nohup ./.venv/bin/python3 "$BOT_FILE" >> "$LOG_FILE" 2>&1 &
echo $! > "$PID_FILE"
sleep 5
kill -0 $(cat "$PID_FILE")
